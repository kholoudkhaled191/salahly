@* Landing Page Home – Arabic (RTL) *@
@* Bundle: Public | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden" dir="rtl">
    <div class="layout-container flex h-full grow flex-col">
        <header class="flex items-center justify-between whitespace-nowrap border-b border-primary/10 bg-white dark:bg-slate-900 px-6 md:px-20 py-3 sticky top-0 z-50 backdrop-blur-lg bg-white/90">
            <div class="flex items-center gap-4">
                <div class="bg-primary p-2 rounded-xl text-white"><span class="material-symbols-outlined">home_repair_service</span></div>
                <h1 class="text-xl font-extrabold tracking-tight">صلاحلي</h1>
            </div>
            <nav class="hidden md:flex items-center gap-8">
                <a class="text-slate-600 text-sm font-medium hover:text-primary transition-colors" href="#">الرئيسية</a>
                <a class="text-slate-600 text-sm font-medium hover:text-primary transition-colors" href="#">الخدمات</a>
                <a class="text-slate-600 text-sm font-medium hover:text-primary transition-colors" href="#">تواصل معنا</a>
            </nav>
            <div class="flex items-center gap-3">
                <a class="text-primary text-sm font-bold hover:underline" href="#">تسجيل الدخول</a>
                <a class="bg-primary text-white px-5 py-2.5 rounded-lg font-bold text-sm hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20" href="#">سجل الآن</a>
            </div>
        </header>
        <main>
            <section class="px-6 md:px-20 py-16 md:py-24 flex flex-col md:flex-row items-center gap-12">
                <div class="flex-1 flex flex-col gap-6">
                    <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-2 rounded-full text-sm font-bold w-fit"><span class="material-symbols-outlined text-base">verified</span> فنيين معتمدين ومراجعين</div>
                    <h2 class="text-4xl md:text-6xl font-black leading-tight tracking-tight">احجز فني صيانة<br /><span class="text-primary">احترافي</span> الآن</h2>
                    <p class="text-slate-500 text-lg max-w-lg">صلاحلي يربطك بأفضل فنيي الصيانة المعتمدين في مصر. سباكة، كهرباء، تكييفات، وأكثر.</p>
                    <div class="flex gap-4 mt-4">
                        <a class="bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-primary/90 transition-all shadow-xl shadow-primary/20 flex items-center gap-2" href="#"><span class="material-symbols-outlined">search</span> ابحث عن فني</a>
                        <a class="border-2 border-slate-200 px-6 py-4 rounded-xl font-bold text-lg hover:border-primary hover:text-primary transition-colors" href="#">كيف يعمل؟</a>
                    </div>
                </div>
                <div class="flex-1 max-w-lg">
                    <div class="aspect-square rounded-2xl bg-slate-100 dark:bg-slate-800 overflow-hidden shadow-2xl">
                        <img alt="صيانة منزلية احترافية" class="w-full h-full object-cover" src="@Model.heroImage" />
                    </div>
                </div>
            </section>
            <section class="px-6 md:px-20 py-16 bg-white dark:bg-slate-900">
                <div class="text-center mb-12">
                    <h3 class="text-3xl font-bold mb-3">خدماتنا</h3>
                    <p class="text-slate-500 max-w-md mx-auto">اكتشف مجموعة واسعة من خدمات الصيانة المنزلية المعتمدة.</p>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    @foreach (var category in Model.Categories)
                    {
                    <div class="group flex flex-col items-center gap-4 p-6 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-primary hover:shadow-lg transition-all cursor-pointer">
                        <div class="size-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors"><span class="material-symbols-outlined text-3xl">@category.iconUrl</span></div>
                        <h4 class="font-bold text-center">@category.name</h4>
                    </div>
                    }
                </div>
            </section>
        </main>
        <footer class="bg-slate-900 text-white py-12 px-6 md:px-20">
            <div class="flex flex-col md:flex-row justify-between gap-8">
                <div><h4 class="font-bold text-xl mb-3">صلاحلي</h4><p class="text-slate-400 text-sm max-w-sm">منصتك الموثوقة لخدمات الصيانة المنزلية في مصر.</p></div>
                <div class="flex gap-12">
                    <div><h5 class="font-bold mb-3">روابط سريعة</h5><div class="flex flex-col gap-2 text-slate-400 text-sm"><a href="#">الرئيسية</a><a href="#">الخدمات</a><a href="#">اتصل بنا</a></div></div>
                    <div><h5 class="font-bold mb-3">قانوني</h5><div class="flex flex-col gap-2 text-slate-400 text-sm"><a href="#">سياسة الخصوصية</a><a href="#">شروط الخدمة</a></div></div>
                </div>
            </div>
            <div class="border-t border-slate-800 mt-8 pt-8 text-center text-slate-500 text-sm">© 2024 صلاحلي. جميع الحقوق محفوظة.</div>
        </footer>
    </div>
</div>

