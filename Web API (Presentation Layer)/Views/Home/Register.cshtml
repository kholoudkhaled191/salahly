@* User Registration (Customer/Worker) – Arabic (RTL) *@
@* Bundle: Public + Worker | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden" dir="rtl">
    <div class="layout-container flex h-full grow flex-col">
        <header class="flex items-center justify-between whitespace-nowrap border-b border-slate-200 dark:border-slate-800 px-6 md:px-20 py-4 bg-white dark:bg-background-dark">
            <div class="flex items-center gap-4 text-primary">
                <div class="size-8 flex items-center justify-center bg-primary text-white rounded-lg"><span class="material-symbols-outlined">build</span></div>
                <h2 class="text-slate-900 dark:text-white text-xl font-bold leading-tight tracking-tight">صلاحلي</h2>
            </div>
            <div class="flex items-center gap-4">
                <p class="hidden md:block text-slate-500 text-sm">لديك حساب بالفعل؟</p>
                <a class="flex items-center justify-center rounded-lg h-10 px-4 bg-primary/10 text-primary text-sm font-bold border border-primary/20 hover:bg-primary/20 transition-all" href="#">تسجيل الدخول</a>
            </div>
        </header>
        <main class="flex flex-1 justify-center py-10 px-4">
            <div class="flex flex-col max-w-[800px] flex-1 bg-white dark:bg-slate-900/50 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-6 md:p-10">
                <div class="mb-8 text-right">
                    <h1 class="text-3xl font-black leading-tight tracking-tight mb-2">إنشاء حساب</h1>
                    <p class="text-slate-500 text-base">انضم إلى صلاحلي للعثور على خبراء أو لتقديم خدماتك في مصر.</p>
                </div>
                <div class="mb-8">
                    <div class="flex border-b border-slate-200 dark:border-slate-800 gap-8">
                        <button class="flex items-center gap-2 border-b-[3px] border-primary text-primary pb-3 px-2 font-bold"><span class="material-symbols-outlined text-xl">person</span> عميل</button>
                        <button class="flex items-center gap-2 border-b-[3px] border-transparent text-slate-400 pb-3 px-2 font-bold hover:text-slate-600 transition-all"><span class="material-symbols-outlined text-xl">handyman</span> فني / صنايعي</button>
                    </div>
                </div>
                <form class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">الاسم الكامل</label>
                            <input class="rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary p-3" placeholder="كما هو موضح في البطاقة الشخصية" type="text" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">العمر</label>
                            <input class="rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary p-3 text-right" placeholder="الحد الأدنى 18 عاماً" type="number" />
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">البريد الإلكتروني</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute right-3 top-3.5 text-slate-400 text-xl">mail</span>
                                <input class="pr-11 w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary p-3 text-right" placeholder="name@example.com" type="email" />
                            </div>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">رقم الهاتف</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute right-3 top-3.5 text-slate-400 text-xl">call</span>
                                <input class="pr-11 w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary p-3 text-right" placeholder="01XXXXXXXXX" type="tel" />
                            </div>
                        </div>
                    </div>
                    <div class="p-4 bg-primary/5 rounded-xl border border-primary/10 space-y-4">
                        <h4 class="text-primary font-bold flex items-center gap-2"><span class="material-symbols-outlined">verified_user</span> مستندات توثيق الحساب للفنيين</h4>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div class="flex flex-col items-center justify-center border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-lg p-4 bg-white dark:bg-slate-800 hover:border-primary transition-colors cursor-pointer text-center">
                                <span class="material-symbols-outlined text-slate-400 text-3xl mb-1">account_circle</span>
                                <span class="text-xs font-medium text-slate-600">الصورة الشخصية</span>
                                <input class="hidden" type="file" />
                            </div>
                            <div class="flex flex-col items-center justify-center border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-lg p-4 bg-white dark:bg-slate-800 hover:border-primary transition-colors cursor-pointer text-center">
                                <span class="material-symbols-outlined text-slate-400 text-3xl mb-1">badge</span>
                                <span class="text-xs font-medium text-slate-600">وجه البطاقة</span>
                                <input class="hidden" type="file" />
                            </div>
                            <div class="flex flex-col items-center justify-center border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-lg p-4 bg-white dark:bg-slate-800 hover:border-primary transition-colors cursor-pointer text-center">
                                <span class="material-symbols-outlined text-slate-400 text-3xl mb-1">credit_card</span>
                                <span class="text-xs font-medium text-slate-600">ظهر البطاقة</span>
                                <input class="hidden" type="file" />
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-slate-200 dark:border-slate-800">
                        <div class="flex flex-col gap-2">
                            <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">اسم المستخدم</label>
                            <input class="rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary p-3" placeholder="اسم_مستخدم_فريد" type="text" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">كلمة المرور</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-3.5 text-slate-400 text-xl cursor-pointer">visibility</span>
                                <input class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:ring-primary focus:border-primary p-3 pl-11" placeholder="••••••••" type="password" />
                            </div>
                        </div>
                    </div>
                    <div class="space-y-4 pt-4">
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input class="mt-1 rounded text-primary focus:ring-primary h-5 w-5 border-slate-300" type="checkbox" />
                            <span class="text-sm text-slate-500 leading-normal">أوافق على <a class="text-primary hover:underline font-semibold" href="#">شروط الخدمة</a> و <a class="text-primary hover:underline font-semibold" href="#">سياسة الخصوصية</a> الخاصة بصلاحلي مصر.</span>
                        </label>
                        <button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/25 transition-all flex items-center justify-center gap-2" type="submit">إنشاء الحساب <span class="material-symbols-outlined" style="transform: scaleX(-1)">arrow_forward</span></button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</div>

