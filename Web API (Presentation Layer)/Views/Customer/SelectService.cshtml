@* Select a Service – Arabic (RTL) *@
@* Bundle: Customer & Booking | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden" dir="rtl">
    <div class="layout-container flex h-full grow flex-col">
        <header class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-6 md:px-20 py-4 sticky top-0 z-50">
            <div class="flex items-center gap-8">
                <div class="flex items-center gap-2 text-primary"><span class="material-symbols-outlined text-3xl">home_repair_service</span><h2 class="text-slate-900 dark:text-white text-xl font-bold leading-tight tracking-tight">صلحلي</h2></div>
                <nav class="hidden md:flex items-center gap-6">
                    <a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="#">الرئيسية</a>
                    <a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="#">طلباتي</a>
                </nav>
            </div>
            <div class="flex flex-1 justify-end gap-4 items-center">
                <div class="bg-primary/10 p-1 rounded-full border border-primary/20">
                    <div class="size-8 rounded-full bg-cover bg-center" style="background-image: url('@Model.profilePicture')"></div>
                </div>
            </div>
        </header>
        <main class="flex-1 flex flex-col max-w-5xl mx-auto w-full px-6 py-8">
            <div class="flex flex-col lg:flex-row gap-8">
                <aside class="w-full lg:w-64 flex flex-col gap-6">
                    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="bg-primary/10 p-2 rounded-lg text-primary"><span class="material-symbols-outlined">waving_hand</span></div>
                            <div><h1 class="text-sm font-semibold">أهلاً بك مجدداً، @Model.fullName</h1><p class="text-slate-500 text-xs">جاهز لإصلاح منزلك؟</p></div>
                        </div>
                    </div>
                    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="flex justify-between items-center mb-2"><p class="text-xs font-bold uppercase tracking-wider">الخطوة 1 من 4</p><p class="text-primary text-xs font-bold">25%</p></div>
                        <div class="w-full h-2 bg-slate-100 dark:bg-slate-800 rounded-full mb-3"><div class="h-full bg-primary rounded-full transition-all duration-500" style="width: 25%;"></div></div>
                    </div>
                </aside>
                <div class="flex-1">
                    <div class="mb-8">
                        <h2 class="text-3xl font-black leading-tight tracking-tight mb-2">بماذا تحتاج للمساعدة؟</h2>
                        <p class="text-slate-500 text-base">اختر فئة للعثور على المحترف المناسب لمشروعك المنزلي.</p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                        @foreach (var category in Model.Categories)
                        {
                        <button class="group flex flex-col items-start p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl hover:border-primary hover:ring-1 hover:ring-primary transition-all text-right">
                            <div class="w-full h-40 bg-slate-100 dark:bg-slate-800 rounded-lg overflow-hidden mb-4 bg-center bg-cover" style="background-image: url('@category.iconUrl');"></div>
                            <div class="flex items-center gap-2 mb-1">
                                <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">handyman</span>
                                <h3 class="text-slate-900 dark:text-white font-bold">@category.name</h3>
                            </div>
                            <p class="text-slate-500 text-sm">@category.description</p>
                        </button>
                        }
                    </div>
                    <div class="mt-12 flex justify-between items-center py-6 border-t border-slate-200 dark:border-slate-800">
                        <button class="px-6 py-2 text-slate-600 font-medium text-sm flex items-center gap-2 hover:bg-slate-100 rounded-lg transition-colors"><span class="material-symbols-outlined">arrow_forward</span> العودة للرئيسية</button>
                        <button class="px-8 py-3 bg-primary text-white font-bold rounded-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">الخطوة التالية <span class="material-symbols-outlined">arrow_back</span></button>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

