@* Notification Center – Arabic (RTL) *@
@* Bundle: Customer & Booking | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden" dir="rtl">
    <div class="layout-container flex h-full grow flex-col">
        <header class="flex items-center justify-between border-b border-primary/10 bg-white dark:bg-slate-900 px-6 lg:px-40 py-4 sticky top-0 z-50">
            <div class="flex items-center gap-4">
                <div class="p-2 bg-primary/10 rounded-lg text-primary"><span class="material-symbols-outlined text-2xl">notifications_active</span></div>
                <div><h2 class="text-xl font-bold leading-tight tracking-tight">التنبيهات</h2><p class="text-xs text-slate-500">تابع تحديثات طلباتك في صلاحلي</p></div>
            </div>
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center rounded-full h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 hover:bg-primary/20 transition-colors"><span class="material-symbols-outlined">search</span></button>
                <button class="flex items-center justify-center rounded-full h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 hover:bg-primary/20 transition-colors"><span class="material-symbols-outlined">settings</span></button>
            </div>
        </header>
        <main class="flex-1 max-w-[960px] mx-auto w-full px-4 py-6">
            <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm mb-6 overflow-hidden">
                <div class="flex border-b border-slate-100 dark:border-slate-800">
                    <button class="flex-1 py-4 text-sm font-bold border-b-2 border-primary text-primary bg-primary/5">الكل (@Model.Notifications.Count)</button>
                    <button class="flex-1 py-4 text-sm font-medium text-slate-500 hover:text-primary transition-colors">غير مقروءة</button>
                    <button class="flex-1 py-4 text-sm font-medium text-slate-500 hover:text-primary transition-colors">تمت قراءتها</button>
                </div>
            </div>
            <div class="space-y-4">
                @foreach (var notification in Model.Notifications)
                {
                <div class="flex flex-col sm:flex-row gap-4 bg-white dark:bg-slate-900 p-5 rounded-xl border-r-4 border-primary shadow-sm hover:shadow-md transition-shadow">
                    <div class="flex items-start gap-4 flex-1">
                        <div class="flex items-center justify-center rounded-xl bg-primary/10 text-primary shrink-0 size-14"><span class="material-symbols-outlined text-3xl">@notification.icon</span></div>
                        <div class="flex flex-col justify-center gap-1">
                            <p class="text-base font-bold">@notification.title</p>
                            <p class="text-sm text-slate-600">@notification.description</p>
                            <div class="flex items-center gap-1 text-xs text-slate-400 mt-1"><span class="material-symbols-outlined text-sm">schedule</span><span>@notification.time</span></div>
                        </div>
                    </div>
                </div>
                }
            </div>
            <div class="flex justify-center mt-10 mb-20">
                <button class="flex items-center gap-2 text-primary font-bold text-sm hover:underline"><span>تحميل المزيد</span><span class="material-symbols-outlined">expand_more</span></button>
            </div>
        </main>
    </div>
</div>

