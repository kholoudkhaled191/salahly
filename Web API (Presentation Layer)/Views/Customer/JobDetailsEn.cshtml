@* Job Details & Scheduling – English (LTR) *@
@* Bundle: Customer & Booking | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden" dir="ltr">
    <div class="layout-container flex h-full grow flex-col">
        <header class="flex items-center justify-between whitespace-nowrap border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-6 lg:px-40 py-3">
            <div class="flex items-center gap-4 text-primary">
                <div class="size-8 flex items-center justify-center bg-primary/10 rounded-lg"><span class="material-symbols-outlined text-primary">home_repair_service</span></div>
                <h2 class="text-slate-900 dark:text-white text-lg font-bold leading-tight tracking-tight">Salahly</h2>
            </div>
            <div class="flex flex-1 justify-end gap-4">
                <button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300"><span class="material-symbols-outlined">notifications</span></button>
                <div class="size-10 rounded-full border border-slate-200 dark:border-slate-700 bg-cover bg-center" style="background-image: url('@Model.profilePicture')"></div>
            </div>
        </header>
        <main class="flex flex-1 justify-center py-8">
            <div class="flex flex-col w-full max-w-[960px] px-6">
                <div class="flex flex-col gap-3 mb-8">
                    <div class="flex justify-between items-center"><p class="font-bold">Step 2 of 4</p><p class="text-primary text-sm font-bold">50% Complete</p></div>
                    <div class="h-2.5 w-full rounded-full bg-slate-200 dark:bg-slate-800"><div class="h-2.5 rounded-full bg-primary" style="width: 50%;"></div></div>
                </div>
                <div class="mb-8">
                    <h1 class="text-3xl font-extrabold leading-tight">Job Details & Scheduling</h1>
                    <p class="text-slate-500 mt-2">Please provide accurate details to help us match the right technician for you.</p>
                </div>
                <div class="space-y-8">
                    <section class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <label class="flex flex-col gap-4">
                            <div class="flex items-center gap-2"><span class="material-symbols-outlined text-primary">edit_note</span><span class="text-lg font-bold">Problem Description</span></div>
                            <textarea class="form-textarea w-full rounded-lg border-slate-300 dark:border-slate-700 bg-transparent focus:ring-primary focus:border-primary min-h-[140px] p-4 placeholder:text-slate-400" placeholder="Please describe the issue you are facing in detail...">@Model.description</textarea>
                        </label>
                    </section>
                    <section class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center gap-2 mb-6"><span class="material-symbols-outlined text-primary">calendar_month</span><span class="text-lg font-bold">Preferred Schedule</span></div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Date</label>
                                <input class="form-input w-full rounded-lg border-slate-300 dark:border-slate-700 bg-transparent focus:ring-primary focus:border-primary" type="date" value="@Model.scheduledDate" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Time</label>
                                <input class="form-input w-full rounded-lg border-slate-300 dark:border-slate-700 bg-transparent focus:ring-primary focus:border-primary" type="time" value="@Model.scheduledTime" />
                            </div>
                        </div>
                    </section>
                    <section class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                        <div class="flex items-center gap-2 mb-4"><span class="material-symbols-outlined text-primary">location_on</span><span class="text-lg font-bold">Service Location</span></div>
                        <textarea class="form-textarea w-full rounded-lg border-slate-300 dark:border-slate-700 bg-transparent focus:ring-primary focus:border-primary min-h-[80px] p-4 placeholder:text-slate-400" placeholder="Enter the service address in detail...">@Model.locationDetails</textarea>
                    </section>
                </div>
                <div class="mt-12 flex items-center justify-between gap-4">
                    <button class="px-8 py-3 rounded-lg font-bold text-slate-600 hover:bg-slate-100 transition-colors">Back</button>
                    <button class="px-10 py-3 rounded-lg font-bold bg-primary text-white hover:bg-primary/90 shadow-lg shadow-primary/20 transition-all flex items-center gap-2"><span>Continue</span><span class="material-symbols-outlined text-sm">arrow_forward</span></button>
                </div>
            </div>
        </main>
    </div>
</div>

