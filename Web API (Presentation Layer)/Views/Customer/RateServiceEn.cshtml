@* Rate Service – English (LTR) *@
@* Bundle: Customer & Booking + Worker | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden" dir="ltr">
    <div class="layout-container flex h-full grow flex-col">
        <header class="flex items-center justify-between whitespace-nowrap border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-4 md:px-10 py-3 sticky top-0 z-50">
            <div class="flex items-center gap-4"><div class="text-primary"><span class="material-symbols-outlined text-3xl">build_circle</span></div><h2 class="text-lg font-bold leading-tight tracking-tight">Salahly</h2></div>
            <div class="flex gap-2">
                <button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700"><span class="material-symbols-outlined">notifications</span></button>
                <button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700"><span class="material-symbols-outlined">close</span></button>
            </div>
        </header>
        <main class="flex flex-1 justify-center py-8 px-4">
            <div class="flex flex-col max-w-[560px] flex-1 bg-white dark:bg-slate-900 rounded-xl shadow-sm p-6 md:p-10 border border-slate-100 dark:border-slate-800">
                <div class="text-center mb-8">
                    <h1 class="text-2xl md:text-3xl font-bold mb-2">Rate Your Service</h1>
                    <p class="text-slate-500 text-sm">Thank you for using Salahly. We hope you're satisfied with the service.</p>
                </div>
                <div class="flex flex-col items-center gap-4 mb-10 p-6 bg-primary/5 dark:bg-primary/10 rounded-xl border border-primary/10">
                    <div class="relative">
                        <div class="size-24 rounded-full border-4 border-white dark:border-slate-800 shadow-md bg-cover bg-center" style="background-image: url('@Model.workerProfilePicture')"></div>
                        <div class="absolute bottom-1 right-1 bg-green-500 size-4 rounded-full border-2 border-white dark:border-slate-800"></div>
                    </div>
                    <div class="text-center">
                        <p class="text-xl font-bold">@Model.workerName</p>
                        <p class="text-primary font-medium text-sm">@Model.workerCategory</p>
                    </div>
                </div>
                <div class="flex flex-col items-center gap-4 mb-8">
                    <h3 class="text-lg font-bold">How was the quality of work?</h3>
                    <div class="flex gap-2 text-amber-400">
                        @for (int i = 1; i <= 5; i++)
                        {
                        <button class="p-1 hover:scale-110 transition-transform"><span class="material-symbols-outlined !text-4xl @(i <= Model.averageRating ? "fill-current" : "text-slate-300")">star</span></button>
                        }
                    </div>
                </div>
                <div class="flex flex-col gap-2 mb-8">
                    <label class="text-base font-bold">Add a Comment (Optional)</label>
                    <textarea class="w-full min-h-[120px] rounded-xl border border-slate-200 dark:border-slate-700 bg-background-light dark:bg-slate-800 p-4 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none placeholder:text-slate-400" placeholder="Describe your experience in detail..."></textarea>
                </div>
                <div class="flex flex-col gap-3">
                    <button class="w-full bg-primary text-white h-14 rounded-xl font-bold text-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all">Submit Rating</button>
                    <button class="w-full bg-transparent text-slate-500 h-12 rounded-xl font-medium text-base hover:bg-slate-50 transition-colors">Skip for Now</button>
                </div>
            </div>
        </main>
    </div>
</div>

