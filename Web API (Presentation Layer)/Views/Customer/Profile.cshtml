@* Customer Profile (Left Sidebar) – Arabic (RTL) *@
@* Bundle: Customer & Booking | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden" dir="rtl">
    <header class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark px-4 md:px-10 py-3 sticky top-0 z-50">
        <div class="flex items-center gap-4">
            <div class="text-primary"><span class="material-symbols-outlined text-4xl">handyman</span></div>
            <h2 class="text-xl font-bold leading-tight tracking-tight">صلاحلي</h2>
        </div>
        <div class="flex flex-1 justify-end gap-4 items-center">
            <button class="flex items-center justify-center rounded-xl h-10 w-10 bg-primary/10 text-primary hover:bg-primary/20 transition-colors"><span class="material-symbols-outlined">notifications</span></button>
            <button class="flex items-center justify-center rounded-xl h-10 w-10 bg-primary/10 text-primary hover:bg-primary/20 transition-colors"><span class="material-symbols-outlined">settings</span></button>
            <div class="size-10 rounded-full border-2 border-primary bg-cover bg-center" style="background-image: url('@Model.profilePicture')"></div>
        </div>
    </header>
    <div class="layout-container flex grow flex-col md:flex-row">
        <aside class="w-full md:w-64 border-l border-slate-200 dark:border-slate-800 p-4 flex flex-col gap-2">
            <div class="flex items-center gap-3 px-3 py-4 border-b border-slate-200 dark:border-slate-800 mb-4">
                <div class="size-12 rounded-full bg-cover bg-center" style="background-image: url('@Model.profilePicture')"></div>
                <div class="flex flex-col">
                    <h1 class="text-base font-bold">@Model.fullName</h1>
                    <p class="text-primary text-xs font-medium">عميل مميز</p>
                </div>
            </div>
            <nav class="flex flex-col gap-1">
                <a class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-primary/5 transition-colors" href="#"><span class="material-symbols-outlined text-slate-500">home</span><span class="text-sm font-medium">الرئيسية</span></a>
                <a class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-primary/5 transition-colors" href="#"><span class="material-symbols-outlined text-slate-500">receipt_long</span><span class="text-sm font-medium">طلباتي</span></a>
                <a class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-primary/5 transition-colors" href="#"><span class="material-symbols-outlined text-slate-500">account_balance_wallet</span><span class="text-sm font-medium">المحفظة</span></a>
                <a class="flex items-center gap-3 px-3 py-3 rounded-xl bg-primary text-white shadow-md shadow-primary/30" href="#"><span class="material-symbols-outlined">person</span><span class="text-sm font-medium">الملف الشخصي</span></a>
                <a class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-primary/5 transition-colors mt-auto text-red-500" href="#"><span class="material-symbols-outlined">logout</span><span class="text-sm font-medium">تسجيل الخروج</span></a>
            </nav>
        </aside>
        <main class="flex-1 p-4 md:p-8">
            <div class="max-w-3xl mx-auto">
                <div class="flex flex-col items-center mb-10">
                    <div class="relative group">
                        <div class="size-32 rounded-full border-4 border-white dark:border-slate-800 shadow-xl bg-cover bg-center" style="background-image: url('@Model.profilePicture')"></div>
                        <button class="absolute bottom-0 right-0 bg-primary text-white p-2 rounded-full shadow-lg border-2 border-white dark:border-slate-800"><span class="material-symbols-outlined text-sm">edit</span></button>
                    </div>
                    <h2 class="text-2xl font-bold mt-4">الملف الشخصي</h2>
                    <p class="text-slate-500 dark:text-slate-400">@Model.address</p>
                </div>
                <div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
                    <h3 class="text-lg font-bold mb-6 border-r-4 border-primary pr-3">بيانات الحساب الشخصية</h3>
                    <form class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">الاسم بالكامل</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">person</span>
                                    <input class="w-full rounded-xl border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 pr-10 focus:border-primary focus:ring-primary h-12" type="text" value="@Model.fullName" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">البريد الإلكتروني</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">mail</span>
                                    <input class="w-full rounded-xl border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 pr-10 focus:border-primary focus:ring-primary h-12" type="email" value="@Model.email" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">رقم الهاتف</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">call</span>
                                    <input class="w-full rounded-xl border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 pr-10 focus:border-primary focus:ring-primary h-12" dir="ltr" type="tel" value="@Model.phoneNumber" />
                                </div>
                            </div>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">العنوان بالتفصيل</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute right-3 top-4 text-slate-400">location_on</span>
                                <textarea class="w-full rounded-xl border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 pr-10 focus:border-primary focus:ring-primary min-h-[100px] py-3">@Model.address</textarea>
                            </div>
                        </div>
                        <div class="pt-4 flex gap-4">
                            <button class="bg-primary text-white px-8 py-3 rounded-xl font-bold hover:bg-primary/90 transition-shadow shadow-lg flex-1 shadow-primary/30" type="submit">حفظ التعديلات</button>
                            <button class="bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 px-8 py-3 rounded-xl font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors" type="button">إلغاء</button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>
</div>

