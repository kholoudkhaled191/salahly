@* Worker Dashboard – Arabic (RTL) *@
@* Bundle: Worker | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="relative flex min-h-screen w-full flex-col" dir="rtl">
    <header class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark px-6 py-4 lg:px-10">
        <div class="flex items-center gap-4">
            <div class="text-primary">
                <span class="material-symbols-outlined text-4xl">home_repair_service</span>
            </div>
            <h2 class="text-slate-900 dark:text-slate-100 text-xl font-bold leading-tight tracking-tight">صلاحلي برو</h2>
        </div>
        <div class="flex flex-1 justify-end items-center gap-4">
            <div class="flex items-center bg-slate-100 dark:bg-slate-800 rounded-full px-4 py-1.5 gap-3 border border-slate-200 dark:border-slate-700">
                <span class="text-xs font-semibold text-slate-600 dark:text-slate-400">الحالة:</span>
                <div class="flex items-center gap-2">
                    @if (Model.availabilityStatus == "Online")
                    {
                        <span class="relative flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                        </span>
                        <span class="text-sm font-bold text-green-600 dark:text-green-400">متصل</span>
                    }
                    else
                    {
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-slate-400"></span>
                        <span class="text-sm font-bold text-slate-500">غير متصل</span>
                    }
                </div>
            </div>
            <div class="flex gap-2">
                <button class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                    <span class="material-symbols-outlined text-xl">notifications</span>
                </button>
                <button class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                    <span class="material-symbols-outlined text-xl">settings</span>
                </button>
            </div>
            <div class="h-10 w-10 rounded-full bg-primary/10 border-2 border-primary overflow-hidden">
                <img alt="@Model.fullName" class="h-full w-full object-cover" src="@Model.profilePicture" />
            </div>
        </div>
    </header>

    <main class="flex-1 flex flex-col lg:flex-row gap-6 p-6 lg:p-10 max-w-[1600px] mx-auto w-full">
        <!-- Worker Profile Sidebar -->
        <aside class="w-full lg:w-80 flex flex-col gap-6">
            <div class="bg-white dark:bg-background-dark p-6 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800">
                <div class="flex flex-col items-center text-center">
                    <div class="size-24 rounded-full border-4 border-primary/20 p-1 mb-4">
                        <img alt="@Model.fullName" class="size-full rounded-full object-cover" src="@Model.profilePicture" />
                    </div>
                    <h3 class="text-lg font-bold">@Model.fullName</h3>
                    <p class="text-slate-500 dark:text-slate-400 text-sm mb-4">@Model.categoryId</p>
                    <div class="flex items-center gap-1 mb-6">
                        <span class="material-symbols-outlined text-yellow-400 fill-current">star</span>
                        <span class="font-bold">@Model.averageRating</span>
                        <span class="text-slate-400 text-sm">(128 مراجعة)</span>
                    </div>
                    <div class="grid grid-cols-2 gap-4 w-full">
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-3 rounded-lg text-right">
                            <p class="text-xs text-slate-500 mb-1">إجمالي الأرباح</p>
                            <p class="text-lg font-bold text-primary">@Model.servicePrice</p>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-3 rounded-lg text-right">
                            <p class="text-xs text-slate-500 mb-1">المهام المنجزة</p>
                            <p class="text-lg font-bold text-primary">56</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Today's Schedule -->
            <div class="bg-white dark:bg-background-dark p-6 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800">
                <h4 class="font-bold mb-4 flex items-center gap-2"><span class="material-symbols-outlined text-primary">calendar_month</span> جدول اليوم</h4>
                <div class="space-y-4">
                    <div class="flex gap-3 border-primary border-r-4 pr-3">
                        <div class="flex flex-col min-w-[50px]">
                            <span class="text-sm font-bold">@Model.scheduledTime</span>
                            <span class="text-xs text-slate-400">صباحاً</span>
                        </div>
                        <div>
                            <p class="text-sm font-semibold">@Model.description</p>
                            <p class="text-xs text-slate-500">@Model.locationDetails</p>
                        </div>
                    </div>
                </div>
                <button class="w-full mt-6 text-sm font-semibold text-primary hover:underline flex items-center justify-center gap-2">عرض التقويم الكامل <span class="material-symbols-outlined text-sm rotate-180">arrow_forward</span></button>
            </div>
        </aside>

        <!-- Available Jobs -->
        <section class="flex-1 flex flex-col gap-6">
            <div class="flex items-center justify-between">
                <h2 class="text-2xl font-bold tracking-tight">وظائف متاحة بالقرب منك</h2>
                <div class="flex gap-2">
                    <button class="flex items-center gap-2 px-3 py-1.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-medium"><span class="material-symbols-outlined text-sm">filter_list</span> تصفية</button>
                    <button class="flex items-center gap-2 px-3 py-1.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-medium"><span class="material-symbols-outlined text-sm">sort</span> ترتيب</button>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-1 gap-4">
                @foreach (var job in Model.AvailableJobs)
                {
                <div class="bg-white dark:bg-background-dark p-6 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 hover:border-primary transition-all group">
                    <div class="flex flex-col xl:flex-row justify-between gap-4">
                        <div class="flex gap-4">
                            <div class="size-16 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                                <span class="material-symbols-outlined text-3xl">bolt</span>
                            </div>
                            <div class="flex flex-col">
                                <div class="flex items-center gap-2 mb-1">
                                    <h3 class="text-lg font-bold group-hover:text-primary transition-colors">@job.description</h3>
                                </div>
                                <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-slate-500 dark:text-slate-400">
                                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">location_on</span> @job.locationDetails</span>
                                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm">schedule</span> @job.scheduledDate @job.scheduledTime</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center justify-between xl:flex-col xl:items-end xl:justify-center gap-2">
                            <p class="text-2xl font-black text-slate-900 dark:text-slate-100">@job.servicePrice</p>
                            <button class="bg-primary text-white px-6 py-2 rounded-lg font-bold hover:bg-primary/90 transition-colors">قبول المهمة</button>
                        </div>
                    </div>
                </div>
                }
            </div>

            <!-- Map View -->
            <div class="mt-4 bg-primary/5 rounded-xl p-8 border border-dashed border-primary/30 flex flex-col items-center justify-center text-center">
                <span class="material-symbols-outlined text-4xl text-primary/40 mb-2">map</span>
                <h3 class="font-bold text-slate-800 dark:text-slate-200">عرض الخريطة</h3>
                <p class="text-sm text-slate-500 max-w-sm">شاهد جميع الوظائف المتاحة على خريطة تفاعلية لتحسين مسارك.</p>
            </div>
        </section>
    </main>

    <footer class="mt-auto border-t border-slate-200 dark:border-slate-800 py-6 px-10 text-center text-slate-500 text-sm">
        <p>© 2024 شركة صلاحلي للتقنيات. يتم مراقبة جميع أنشطة العمال لضمان الجودة.</p>
    </footer>
</div>

