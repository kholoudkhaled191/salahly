@* Admin Dashboard – English (LTR) *@
@* Bundle: Admin & Governance | Layout assumes _Layout loads TailwindCSS + main-theme.css *@

<div class="flex min-h-screen" dir="ltr">
    <!-- Side Navigation -->
    <aside class="w-64 border-primary/10 bg-white dark:bg-slate-900 flex flex-col fixed h-full border-r">
        <div class="p-6 flex items-center gap-3">
            <div class="bg-primary p-2 rounded-lg">
                <span class="material-symbols-outlined text-white">home_repair_service</span>
            </div>
            <h1 class="text-xl font-bold tracking-tight text-primary">Salahly</h1>
        </div>
        <nav class="flex-1 px-4 space-y-1">
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary text-white" href="#"><span class="material-symbols-outlined">dashboard</span><span class="text-sm font-medium">Dashboard</span></a>
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-primary/10 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">calendar_month</span><span class="text-sm font-medium">Bookings</span></a>
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-primary/10 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">group</span><span class="text-sm font-medium">Manage Users</span></a>
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-primary/10 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">engineering</span><span class="text-sm font-medium">Technicians</span></a>
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-primary/10 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">payments</span><span class="text-sm font-medium">Revenue</span></a>
            <div class="pt-4 pb-2 px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">System</div>
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-primary/10 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">notifications</span><span class="text-sm font-medium flex-1">Notifications</span><span class="bg-red-500 text-white text-[10px] px-1.5 py-0.5 rounded-full">4</span></a>
            <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-primary/10 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">settings</span><span class="text-sm font-medium">Settings</span></a>
        </nav>
        <div class="p-4 border-t border-primary/10">
            <div class="flex items-center gap-3 p-2">
                <div class="w-10 h-10 rounded-full bg-primary/20 bg-cover bg-center" style="background-image: url('@Model.profilePicture')"></div>
                <div class="flex flex-col">
                    <span class="text-sm font-bold">@Model.fullName</span>
                    <span class="text-xs text-slate-500">@Model.role</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-8 ml-64">
        <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div>
                <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Dashboard Overview</h2>
                <p class="text-slate-500 dark:text-slate-400">Real-time platform performance and management.</p>
            </div>
            <div class="flex items-center gap-3">
                <div class="relative">
                    <span class="material-symbols-outlined absolute top-1/2 -translate-y-1/2 text-slate-400 left-3">search</span>
                    <input class="pl-10 pr-4 py-2 bg-white dark:bg-slate-900 border border-primary/10 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none text-sm w-64" placeholder="Search platform..." type="text" />
                </div>
                <button class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 hover:bg-primary/90 transition-colors"><span class="material-symbols-outlined text-sm">download</span> Export Report</button>
            </div>
        </header>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-primary/5 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-2 bg-primary/10 rounded-lg"><span class="material-symbols-outlined text-primary">shopping_cart</span></div>
                    <span class="text-green-500 text-xs font-bold flex items-center bg-green-50 px-2 py-1 rounded-full"><span class="material-symbols-outlined text-[14px]">trending_up</span> 12%</span>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Total Bookings</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white">2,450</h3>
            </div>
            <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-primary/5 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-2 bg-primary/10 rounded-lg"><span class="material-symbols-outlined text-primary">account_balance_wallet</span></div>
                    <span class="text-green-500 text-xs font-bold flex items-center bg-green-50 px-2 py-1 rounded-full"><span class="material-symbols-outlined text-[14px]">trending_up</span> 8%</span>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Monthly Revenue</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white">85,000 EGP</h3>
            </div>
            <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-primary/5 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-2 bg-primary/10 rounded-lg"><span class="material-symbols-outlined text-primary">engineering</span></div>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Active Technicians</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white">320</h3>
            </div>
            <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-primary/5 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-2 bg-primary/10 rounded-lg"><span class="material-symbols-outlined text-primary">pending_actions</span></div>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Approvals</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white">12</h3>
            </div>
        </div>

        <!-- User Management Table -->
        <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
            <div class="xl:col-span-2 bg-white dark:bg-slate-900 rounded-xl border border-primary/5 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-primary/5 flex justify-between items-center">
                    <h3 class="text-lg font-bold">New Users & Technicians</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-primary/5 text-slate-600 dark:text-slate-400 text-xs uppercase font-bold tracking-wider">
                            <tr>
                                <th class="px-6 py-4">User</th>
                                <th class="px-6 py-4">Role</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Joined Date</th>
                                <th class="px-6 py-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-primary/5">
                            @foreach (var user in Model.Users)
                            {
                            <tr class="hover:bg-primary/5 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-slate-200 bg-cover bg-center" style="background-image: url('@user.profilePicture')"></div>
                                        <div class="flex flex-col"><span class="text-sm font-bold">@user.fullName</span></div>
                                    </div>
                                </td>
                                <td class="px-6 py-4"><span class="text-xs font-medium px-2 py-1 bg-blue-100 text-blue-600 rounded-full">@user.role</span></td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-1.5">
                                        <div class="w-1.5 h-1.5 rounded-full @(user.isActive ? "bg-green-500" : "bg-amber-500")"></div>
                                        <span class="text-xs">@(user.isActive ? "Active" : "Pending")</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-xs text-slate-500">@user.joinedDate</td>
                                <td class="px-6 py-4 text-right">
                                    <button class="text-slate-400 hover:text-primary"><span class="material-symbols-outlined">more_vert</span></button>
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- System Alerts -->
            <div class="space-y-6">
                <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-primary/5 shadow-sm">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-lg font-bold">System Alerts</h3>
                        <span class="bg-red-500 text-white text-[10px] font-black px-2 py-0.5 rounded-full">URGENT</span>
                    </div>
                    <div class="space-y-4">
                        <div class="flex gap-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/20">
                            <span class="material-symbols-outlined text-red-500">error</span>
                            <div>
                                <p class="text-sm font-bold text-red-900 dark:text-red-100">@Model.description</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-primary/5 shadow-sm">
                    <h3 class="text-lg font-bold mb-6">Pending Approvals</h3>
                    <div class="space-y-4">
                        @foreach (var approval in Model.PendingApprovals)
                        {
                        <div class="flex items-center justify-between border-b border-primary/5 pb-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-primary">verified_user</span>
                                </div>
                                <div>
                                    <p class="text-sm font-bold">@approval.name</p>
                                    <p class="text-xs text-slate-500">@approval.description</p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <button class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg transition-colors"><span class="material-symbols-outlined text-[20px]">close</span></button>
                                <button class="p-1.5 text-green-500 hover:bg-green-50 rounded-lg transition-colors"><span class="material-symbols-outlined text-[20px]">check</span></button>
                            </div>
                        </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

